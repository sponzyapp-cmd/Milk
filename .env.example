# Milk Sales Tracker Environment Configuration
# This is an example file. Copy to .env.local and configure as needed.

# The app is 100% offline-first and doesn't require external services.
# All data is stored in browser IndexedDB via Dexie.

# If you plan to add cloud sync in the future, add credentials here:
# DATABASE_URL=your_cloud_database_url
# API_KEY=your_api_key

# Optional: For future notifications
# NOTIFICATION_API_KEY=your_notification_service_key

# App configuration (optional overrides)
# NEXT_PUBLIC_APP_NAME=Milk Sales Tracker
# NEXT_PUBLIC_MAX_DATA_RETENTION_MONTHS=6
